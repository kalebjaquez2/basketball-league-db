<Page x:Class="Frontend.RosterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Frontend"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RosterPage">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <Button Content="← BACK" Click="Back_Click"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#555" FontSize="11" FontWeight="Bold"/>

            <TextBlock x:Name="PageTitle"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="White"/>

            <Rectangle Height="3" Width="80" Fill="#F05A28" Margin="0,12,0,0"/>
        </StackPanel>

        <!-- Players -->
        <ListView x:Name="PlayersList" Grid.Row="1" Background="Transparent" BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1A1A1A" Padding="16" Margin="0,0,0,10" CornerRadius="6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                            <TextBlock Text="{Binding PlayerName}" 
                                       Foreground="White" FontSize="18" FontWeight="Bold"/>

                            <TextBlock Text="{Binding Position}" 
                                       Foreground="#999" FontSize="14" Margin="20,0,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
