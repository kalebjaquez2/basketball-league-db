<Page x:Class="Frontend.RosterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Frontend"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RosterPage" Background="#0D0D0D">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Header spans both columns -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,30">
            <StackPanel>
                <Button Content="← BACK" Click="Back_Click"
                        Style="{StaticResource GhostButton}"
                        FontSize="11" FontWeight="Bold"
                        HorizontalAlignment="Left"/>
                <TextBlock x:Name="PageTitle"
                           FontSize="36" FontWeight="Bold" Foreground="White"/>
                <Rectangle Height="3" Width="80" Fill="#F05A28"
                           HorizontalAlignment="Left" Margin="0,12,0,0"/>
            </StackPanel>

            <!-- Add Player button aligned to the bottom-right of the header -->
            <Button x:Name="AddPlayerButton" Click="AddPlayer_Click" Cursor="Hand"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Background="Transparent" BorderThickness="0">
                <Border Background="#F05A28" CornerRadius="6" Padding="18,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="ADD PLAYER" FontSize="12"
                                   FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Button>
        </Grid>

        <!-- Left: Players List -->
        <ListView x:Name="PlayersList" Grid.Row="1" Grid.Column="0"
                  Background="Transparent" BorderThickness="0"
                  Margin="0,0,20,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1A1A1A" Padding="16" Margin="0,0,0,10"
                            CornerRadius="6" Width="450">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Jersey # — view -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding JerseyNumber, StringFormat='#{0}'}"
                                       Foreground="#F05A28" FontSize="16" FontWeight="Bold"
                                       Margin="0,0,16,0" VerticalAlignment="Center"
                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}"/>
                            <!-- Jersey # — edit -->
                            <TextBox Grid.Column="0" Width="48"
                                     Text="{Binding EditJerseyNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#242424" Foreground="#F05A28"
                                     BorderBrush="#F05A28" BorderThickness="1"
                                     Padding="4,2" FontSize="14" FontWeight="Bold"
                                     Margin="0,0,10,0" VerticalAlignment="Center"
                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>

                            <!-- First + Last name — always shown, never editable -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding FirstName, StringFormat='{}{0} '}"
                                       Foreground="White" FontSize="16" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding LastName}"
                                       Foreground="White" FontSize="16" FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <!-- Position badge — view -->
                            <Border Grid.Column="3" Background="#2E2E2E"
                                    CornerRadius="4" Padding="8,4" Margin="16,0,0,0"
                                    Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                                <TextBlock Text="{Binding Position}"
                                           Foreground="#F05A28" FontSize="12" FontWeight="Bold"/>
                            </Border>
                            <!-- Position — edit -->
                            <TextBox Grid.Column="3" Width="56"
                                     Text="{Binding EditPosition, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#242424" Foreground="#F05A28"
                                     BorderBrush="#F05A28" BorderThickness="1"
                                     Padding="4,2" FontSize="12" FontWeight="Bold"
                                     Margin="10,0,0,0" VerticalAlignment="Center"
                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>

                            <!-- ⋮ — view mode only -->
                            <Button Grid.Column="4"
                                    Content="⋮" Width="28" Height="28"
                                    Style="{StaticResource GhostButton}"
                                    FontSize="16"
                                    Margin="8,0,0,0" Tag="{Binding}"
                                    Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}"
                                    Click="PlayerOptions_Click">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Edit" Click="EditPlayer_Click"/>
                                        <MenuItem Header="Delete" Style="{StaticResource DeleteMenuItemStyle}" Click="DeletePlayer_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <!-- ✓ ✗ — edit mode only -->
                            <StackPanel Grid.Column="4" Orientation="Horizontal"
                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                <Button Content="✓" Width="26" Height="26" Margin="0,0,4,0"
                                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                                        FontSize="13" Cursor="Hand" Tag="{Binding}"
                                        Click="SavePlayer_Click"/>
                                <Button Content="✗" Width="26" Height="26"
                                        Background="#5A2A2A" Foreground="White" BorderThickness="0"
                                        FontSize="13" Cursor="Hand" Tag="{Binding}"
                                        Click="CancelPlayerEdit_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Right: Top Scorers Panel -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="#1A1A1A" BorderBrush="#2E2E2E"
                BorderThickness="1" CornerRadius="8"
                Padding="20" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="TOP SCORERS" FontSize="12" FontWeight="Bold"
                           Foreground="#F05A28" Margin="0,0,0,16"/>

                <!-- Column Headers -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="PLAYER" FontSize="10"
                               Foreground="#555555" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="GP" FontSize="10"
                               Foreground="#555555" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="PTS" FontSize="10"
                               Foreground="#555555" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="PPG" FontSize="10"
                               Foreground="#555555" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </Grid>

                <Rectangle Height="1" Fill="#2E2E2E" Margin="0,0,0,8"/>

                <!-- Scorer Rows -->
                <ItemsControl x:Name="TopScorersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="{Binding TeamRank}"
                                               FontSize="10" Foreground="#F05A28"
                                               FontWeight="Bold" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PlayerName}"
                                               FontSize="12" Foreground="White"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding GamesPlayed}"
                                           FontSize="12" Foreground="#999999"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding TotalPoints}"
                                           FontSize="12" Foreground="White"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding AveragePointsPerGame}"
                                           FontSize="12" Foreground="#F05A28"
                                           HorizontalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</Page>