<Page x:Class="Frontend.SeasonsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Seasons"
      Background="#0D0D0D">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,40">
            <Button Content="← BACK TO LEAGUES" 
                    Click="Back_Click" 
                    HorizontalAlignment="Left"
                    Background="Transparent" 
                    BorderThickness="0" 
                    Foreground="#999999" 
                    Cursor="Hand"
                    FontSize="12"
                    FontWeight="Bold"
                    Margin="0,0,0,20"/>

            <TextBlock Text="VIEWING SEASONS FOR" FontSize="14" Foreground="#999999" Margin="0,0,0,4"/>
            <TextBlock x:Name="LeagueHeader" 
                       FontSize="36" 
                       FontWeight="Bold" 
                       Foreground="White"
                       Text="League Name"/>
            <Rectangle Height="3" Width="80" Fill="#F05A28" HorizontalAlignment="Left" Margin="0,12,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="AVAILABLE SEASONS" FontSize="12" Foreground="#999999" Margin="0,0,0,16"/>

                <ItemsControl x:Name="SeasonsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="260" 
                                    Height="160" 
                                    Margin="0,0,16,16" 
                                    CornerRadius="8" 
                                    Background="#242424" 
                                    BorderBrush="#2E2E2E" 
                                    BorderThickness="1">

                                <Border Padding="20">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="📅" 
                                                   FontSize="32" 
                                                   HorizontalAlignment="Center" 
                                                   Margin="0,0,0,12"/>

                                        <TextBlock Text="{Binding StartDate, StringFormat=yyyy}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold" 
                                                   Foreground="White" 
                                                   HorizontalAlignment="Center"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding StartDate, StringFormat=d}" 
                                                       Foreground="#999999" 
                                                       FontSize="12"/>
                                            <TextBlock Text=" - " 
                                                       Foreground="#999999" 
                                                       FontSize="12"/>
                                            <TextBlock Text="{Binding EndDate, StringFormat=d}" 
                                                       Foreground="#999999" 
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>