<Page x:Class="Frontend.SeasonsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Seasons" Background="#0D0D0D">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,40">
            <Button Content="← BACK TO LEAGUES" Click="Back_Click"
                    Style="{StaticResource GhostButton}"
                    FontSize="11" FontWeight="Bold" HorizontalAlignment="Left" Margin="0,0,0,20"/>
            <TextBlock Text="VIEWING SEASONS FOR" FontSize="12" Foreground="#999999" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <TextBlock x:Name="LeagueHeader" FontSize="36" FontWeight="Bold" Foreground="White" Text="League Name"/>
            <Rectangle Height="3" Width="80" Fill="#F05A28" HorizontalAlignment="Left" Margin="0,12,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="TilesPanel" Orientation="Horizontal"
                       Width="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth}"/>
        </ScrollViewer>
    </Grid>
</Page>