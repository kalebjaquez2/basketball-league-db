<Window x:Class="Frontend.AddSeasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Season" Height="380" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#0D0D0D">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F05A28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF6A35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1A" CornerRadius="8,8,0,0">
            <Grid>
                <TextBlock Text="ADD NEW SEASON" Foreground="#999999" FontWeight="Bold"
                           FontSize="11" VerticalAlignment="Center" Margin="16,0"/>
                <Button Content="✕" HorizontalAlignment="Right" Width="40" Background="Transparent"
                        BorderThickness="0" Foreground="#555555" Cursor="Hand" Click="Close_Click"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="30">
            <TextBlock Text="START DATE" Style="{StaticResource FieldLabel}"/>
            <DatePicker x:Name="StartDatePicker" Margin="0,0,0,20"/>

            <TextBlock Text="END DATE" Style="{StaticResource FieldLabel}"/>
            <DatePicker x:Name="EndDatePicker" Margin="0,0,0,20"/>

            <TextBlock x:Name="ErrorMessage" Foreground="#FF4444" FontSize="12" Margin="0,0,0,10" Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="CANCEL" Click="Close_Click" Background="Transparent" Foreground="#666" Padding="12,10" Margin="0,0,15,0" Cursor="Hand" BorderThickness="0"/>
                <Button Content="SAVE SEASON" Style="{StaticResource SaveButtonStyle}" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>