<Window x:Class="Frontend.AddLeagueDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add League" Height="380" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#0D0D0D">

    <Window.Resources>

        <!-- Label Style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2E2E2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#F05A28"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cancel Button Style -->
        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="BorderBrush" Value="#2E2E2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A1A1A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Save Button Style -->
        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F05A28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF6A35"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D94E20"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#444444"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Outer Grid: Title Bar + Form -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <!-- Custom Title Bar -->
            <RowDefinition Height="*"/>
            <!-- Form Content -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#1A1A1A" CornerRadius="8,8,0,0">
            <Grid>
                <TextBlock Text="ADD LEAGUE" Foreground="#999999" FontWeight="Bold"
                   FontSize="11" VerticalAlignment="Center" Margin="16,0"/>

                <Button Content="✕" HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Width="45" Background="Transparent"
                BorderThickness="0" Cursor="Hand"
                Click="CloseButton_Click" x:Name="HeaderCloseBtn">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" x:Name="BtnBorder">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="BtnContent"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#F05A28"/>
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#242424"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="#555555"/>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Form Content -->
        <Grid Grid.Row="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- League Name -->
                <RowDefinition Height="16"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Location -->
                <RowDefinition Height="*"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Error Message -->
                <RowDefinition Height="16"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- League Name Field -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="LEAGUE NAME" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="LeagueNameBox" Style="{StaticResource InputBox}"
                         MaxLength="64" TextChanged="Input_TextChanged"/>
            </StackPanel>

            <!-- Location Field -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="LOCATION" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="LocationBox" Style="{StaticResource InputBox}"
                         MaxLength="64" TextChanged="Input_TextChanged"/>
            </StackPanel>

            <!-- Error Message -->
            <TextBlock x:Name="ErrorMessage" Grid.Row="4"
                       Foreground="#FF4444" FontSize="12"
                       TextWrapping="Wrap" Visibility="Collapsed"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource CancelButtonStyle}"
                        Content="CANCEL" Click="Cancel_Click" Margin="0,0,10,0"/>
                <Button x:Name="SaveButton" Style="{StaticResource SaveButtonStyle}"
                        Content="SAVE LEAGUE" Click="Save_Click" IsEnabled="False"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>