<Window x:Class="Frontend.AddGameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Game" Height="480" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="#0D0D0D">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,15,0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1A" CornerRadius="8,8,0,0">
            <Grid>
                <TextBlock Text="SCHEDULE NEW GAME" Foreground="#999999" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="16,0"/>
                <Button Content="✕" HorizontalAlignment="Right" Width="40" Background="Transparent" BorderThickness="0" Foreground="#555555" Cursor="Hand" Click="Close_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,10,30,30">
                <TextBlock Text="HOME TEAM" Style="{StaticResource FieldLabel}" Margin="0,5,0,6"/>
                <ComboBox x:Name="HomeTeamCombo" DisplayMemberPath="TeamName" SelectedValuePath="TeamID"/>

                <TextBlock Text="AWAY TEAM" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="AwayTeamCombo" DisplayMemberPath="TeamName" SelectedValuePath="TeamID"/>

                <TextBlock Text="DATE" Style="{StaticResource FieldLabel}"/>
                <DatePicker x:Name="GameDatePicker"/>

                <TextBlock Text="COURT NUMBER" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="CourtBox" Background="#1A1A1A" Foreground="White" BorderBrush="#2E2E2E" Padding="8" Text="1"/>

                <TextBlock x:Name="ErrorMessage" Foreground="#FF4444" FontSize="12" Margin="0,15,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                    <Button Content="CANCEL" Click="Close_Click" Background="Transparent" Foreground="#666" Padding="12,10" Margin="0,0,15,0" Cursor="Hand" BorderThickness="0"/>
                    <Button Content="SAVE GAME" Background="#F05A28" Foreground="White" FontWeight="Bold" Padding="20,10" Click="Save_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>