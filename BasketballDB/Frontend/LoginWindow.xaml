<Window x:Class="Frontend.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="460" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2E2E2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#F05A28"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PassBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2E2E2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="OrangeBtn" TargetType="Button">
            <Setter Property="Background" Value="#F05A28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" Margin="0,12"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF6A35"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D44A18"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0D0D0D" CornerRadius="10"
            BorderBrush="#2E2E2E" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title bar -->
                <RowDefinition Height="56"/>
                <!-- Login form — takes all remaining space -->
                <RowDefinition Height="*"/>
                <!-- Create Account bar — always pinned at bottom -->
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ── -->
            <Border Grid.Row="0" Background="#1A1A1A" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel HorizontalAlignment="Left" Margin="20,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="REC CENTER BASKETBALL"
                                   Foreground="White" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="PLAYER PORTAL"
                                   Foreground="#F05A28" FontSize="10" FontWeight="Bold"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" Width="40"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#555555" Cursor="Hand" Click="Exit_Click"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── Login form ── -->
            <StackPanel Grid.Row="1" Margin="36,24,36,16" VerticalAlignment="Top">

                <TextBlock Text="SIGN IN" FontSize="22" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,4"/>
                <TextBlock Text="Enter your credentials to continue"
                           Foreground="#666666" FontSize="12" Margin="0,0,0,24"/>

                <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="UsernameBox" Style="{StaticResource InputBox}"
                         MaxLength="64" Margin="0,0,0,14"/>

                <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource PassBox}"
                             MaxLength="128" Margin="0,0,0,4"
                             KeyDown="Password_KeyDown"/>

                <TextBlock x:Name="ErrorMessage" Foreground="#FF4444" FontSize="12"
                           Margin="0,8,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                <Button Content="LOGIN" Style="{StaticResource OrangeBtn}"
                        Margin="0,16,0,0" Click="Login_Click"/>
            </StackPanel>

            <!-- ── Create Account bar — always visible at bottom ── -->
            <Border Grid.Row="2" Background="#141414"
                    BorderBrush="#2E2E2E" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="New here?  "
                               Foreground="#666666" FontSize="13"
                               VerticalAlignment="Center"/>
                    <Button Click="CreateAccount_Click" Cursor="Hand"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock x:Name="lnk" Text="Create an account"
                                           Foreground="#F05A28" FontSize="13"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="lnk"
                                                Property="TextDecorations"
                                                Value="Underline"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
