<Window x:Class="Frontend.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rec Center Basketball" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0D"
        WindowStyle="None"
        ResizeMode="CanResize">

	<WindowChrome.WindowChrome>
		<WindowChrome CaptionHeight="40" ResizeBorderThickness="4"
                      CornerRadius="0" GlassFrameThickness="0"/>
	</WindowChrome.WindowChrome>

	<Window.Resources>

		<!-- Window control button (minimize / maximize) -->
		<Style x:Key="WinCtrlBtn" TargetType="Button">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Foreground" Value="#888888"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Width" Value="52"/>
			<Setter Property="Height" Value="40"/>
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd" Background="{TemplateBinding Background}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
								<Setter Property="Foreground" Value="White"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#333333"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Close button (red hover) -->
		<Style x:Key="CloseBtn" TargetType="Button">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Foreground" Value="#888888"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Width" Value="52"/>
			<Setter Property="Height" Value="40"/>
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd" Background="{TemplateBinding Background}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
								<Setter Property="Foreground" Value="White"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#E81123"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- League Tile Style -->
		<Style x:Key="LeagueTileStyle" TargetType="Button">
			<Setter Property="Background" Value="#242424"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderBrush" Value="#2E2E2E"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Width" Value="260"/>
			<Setter Property="Height" Value="160"/>
			<Setter Property="Margin" Value="0,0,16,16"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#2E2E2E"/>
								<Setter Property="BorderBrush" Value="#F05A28"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="#333333"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Add Tile Style -->
		<Style x:Key="AddTileStyle" TargetType="Button">
			<Setter Property="Background" Value="#1A1A1A"/>
			<Setter Property="Foreground" Value="#999999"/>
			<Setter Property="BorderBrush" Value="#444444"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Width" Value="260"/>
			<Setter Property="Height" Value="160"/>
			<Setter Property="Margin" Value="0,0,16,16"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#242424"/>
								<Setter Property="BorderBrush" Value="#F05A28"/>
								<Setter Property="Foreground" Value="White"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="#2E2E2E"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="40"/>
			<RowDefinition Height="36"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Chrome bar: window controls only -->
		<Grid Grid.Row="0" Background="#111111">
			<Border VerticalAlignment="Bottom" Height="1" Background="#1E1E1E"/>
			<StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
				<Button Content="—" Style="{StaticResource WinCtrlBtn}" Click="Minimize_Click"/>
				<Button x:Name="MaxRestoreBtn" Content="□" Style="{StaticResource WinCtrlBtn}" Click="MaxRestore_Click"/>
				<Button Content="✕" Style="{StaticResource CloseBtn}" Click="CloseWindow_Click"/>
			</StackPanel>
		</Grid>

		<!-- Session bar -->
		<Border Grid.Row="1" Background="#1A1A1A" BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
			<Grid Margin="20,0">
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="Logged in as " Foreground="#555555" FontSize="11"
                               VerticalAlignment="Center"/>
					<TextBlock x:Name="UsernameLabel" Foreground="#F05A28"
                               FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
				</StackPanel>
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
					<Button x:Name="ManageAccountsButton" Content="MANAGE ACCOUNTS"
                            Click="ManageAccounts_Click"
                            Style="{StaticResource GhostButton}"
                            Foreground="#F05A28" FontWeight="Bold" FontSize="11"
                            Margin="0,0,20,0" Visibility="Collapsed"/>
					<Button Content="SIGN OUT" Click="SignOut_Click"
                            Style="{StaticResource GhostButton}" FontSize="11"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- HOME SCREEN -->
		<ScrollViewer x:Name="HomeScreen" Grid.Row="2" VerticalScrollBarVisibility="Auto">
			<StackPanel Margin="40">

				<!-- Hero Header -->
				<StackPanel Margin="0,20,0,40">
					<TextBlock Text="WELCOME TO" FontSize="14" Foreground="#999999" Margin="0,0,0,4"/>
					<TextBlock Text="REC CENTER BASKETBALL" FontSize="36" FontWeight="Bold" Foreground="White"/>
					<Rectangle Height="3" Width="80" Fill="#F05A28" HorizontalAlignment="Left" Margin="0,12,0,0"/>
				</StackPanel>

				<!-- Leagues Label -->
				<TextBlock Text="LEAGUES" FontSize="12" Foreground="#999999" Margin="0,0,0,16"/>

				<!-- Tiles: Add tile first, then league tiles -->
				<WrapPanel>

					<!-- Add League Tile (admin only) -->
					<Button x:Name="AddLeagueButton" Style="{StaticResource AddTileStyle}"
					        Click="AddLeague_Click">
						<StackPanel HorizontalAlignment="Center">
							<TextBlock Text="+" FontSize="40" HorizontalAlignment="Center"
                                       Foreground="#F05A28" Margin="0,0,0,8"/>
							<TextBlock Text="Add League" FontSize="16"
                                       HorizontalAlignment="Center" Foreground="#999999"/>
						</StackPanel>
					</Button>

					<!-- League Tiles -->
					<ItemsControl x:Name="LeagueTilesControl">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
                                <Button Style="{StaticResource LeagueTileStyle}"
                                        Tag="{Binding LeagueID}"
                                        Click="LeagueTile_Click"
										HorizontalContentAlignment="Center"
										VerticalContentAlignment="Center">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="🏀" FontSize="32"
                                                   HorizontalAlignment="Center" Margin="0,0,0,12" />
                                        <TextBlock Text="{Binding LeagueName}" FontSize="18"
                                                   Padding="12"
                                                   TextWrapping="Wrap"
                                                   FontWeight="Bold" Foreground="White"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"/>
									</StackPanel>
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</WrapPanel>

			</StackPanel>
		</ScrollViewer>

		<!-- CONTENT FRAME - other views load here -->
		<Frame x:Name="MainFrame" Grid.Row="2" NavigationUIVisibility="Hidden"
               Background="#0D0D0D" Visibility="Collapsed"/>

	</Grid>
</Window>
