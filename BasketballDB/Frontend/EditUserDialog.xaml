<Window x:Class="Frontend.EditUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit User" Height="380" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="#0D0D0D">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2E2E2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#F05A28"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PassBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2E2E2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="#F05A28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF6A35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1A" CornerRadius="8,8,0,0">
            <Grid>
                <TextBlock x:Name="TitleLabel" Text="EDIT USER" Foreground="#999999"
                           FontWeight="Bold" FontSize="11"
                           VerticalAlignment="Center" Margin="16,0"/>
                <Button Content="✕" HorizontalAlignment="Right" Width="40"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#555555" Cursor="Hand" Click="Close_Click"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="30">

            <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="UsernameBox" Style="{StaticResource InputBox}"
                     MaxLength="64" Margin="0,0,0,16"/>

            <TextBlock Text="NEW PASSWORD" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource PassBox}"
                         MaxLength="128" Margin="0,0,0,6"/>
            <TextBlock Text="Leave blank to keep current password"
                       Foreground="#555555" FontSize="10" Margin="0,0,0,16"/>

            <TextBlock Text="CONFIRM NEW PASSWORD" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource PassBox}"
                         MaxLength="128" Margin="0,0,0,16"/>

            <TextBlock x:Name="ErrorMessage" Foreground="#FF4444" FontSize="12"
                       Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="CANCEL" Click="Close_Click"
                        Background="Transparent" Foreground="#666"
                        Margin="0,0,15,0" Cursor="Hand" BorderThickness="0"/>
                <Button Content="SAVE CHANGES" Style="{StaticResource SaveBtn}"
                        Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
