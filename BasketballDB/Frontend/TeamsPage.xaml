<Page x:Class="Frontend.TeamsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Teams" Background="#0D0D0D">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,40">
            <Button Content="← BACK TO SEASONS" Click="Back_Click" 
                    Background="Transparent" BorderThickness="0" Foreground="#555555" 
                    FontSize="11" FontWeight="Bold" Cursor="Hand" HorizontalAlignment="Left" Margin="0,0,0,20"/>

            <TextBlock Text="MANAGING TEAMS FOR" FontSize="14" Foreground="#999999" Margin="0,0,0,4"/>
            <TextBlock x:Name="SeasonHeader" FontSize="36" FontWeight="Bold" Foreground="White" Text="Season Name"/>
            <Rectangle Height="3" Width="80" Fill="#F05A28" HorizontalAlignment="Left" Margin="0,12,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="TEAM ROSTER" FontSize="12" Foreground="#999999" Margin="0,0,0,16"/>

                <ItemsControl x:Name="TeamsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemsSource>
                        <CompositeCollection>
                            <ContentControl>
                                <Button Width="260" Height="160" Margin="0,0,16,16" Cursor="Hand" Click="AddTeam_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#1A1A1A" BorderBrush="#444444" BorderThickness="1" CornerRadius="8" x:Name="MainBorder">
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="+" FontSize="40" Foreground="#F05A28" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                    <TextBlock Text="Add Team" FontSize="16" Foreground="#999999" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="MainBorder" Property="Background" Value="#242424"/>
                                                    <Setter TargetName="MainBorder" Property="BorderBrush" Value="#F05A28"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </ContentControl>

                            <CollectionContainer x:Name="TeamsDataContainer" />
                        </CompositeCollection>
                    </ItemsControl.ItemsSource>

					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Width="260" Height="160"
									CornerRadius="8"
									Background="#242424"
									BorderBrush="#2E2E2E"
									BorderThickness="1"
									Margin="0,0,16,16"
									ClipToBounds="True">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition Height="*"/>
										<RowDefinition Height="30"/>
									</Grid.RowDefinitions>

									<StackPanel Grid.Row="0" VerticalAlignment="Center">
										<TextBlock Text="🛡️"
												   FontSize="28"
												   HorizontalAlignment="Center"
												   Margin="0,0,0,4"/>

										<TextBlock Text="{Binding TeamName}"
												   FontSize="18"
												   FontWeight="Bold"
												   Foreground="White"
												   TextWrapping="Wrap"
												   TextAlignment="Center"
												   Margin="12,0,12,0"/>
									</StackPanel>

									<Grid Grid.Row="1">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>

										<Button Grid.Column="0"
												Content="SCHEDULE"
												Click="TeamTile_Click"
												Tag="{Binding TeamID}"
												Background="#F05A28"
												Foreground="White"
												BorderThickness="0"
												FontWeight="SemiBold"
												FontSize="11"
												Cursor="Hand">
											<Button.Resources>
												<Style TargetType="Border">
													<Setter Property="CornerRadius" Value="0,0,0,8"/>
												</Style>
											</Button.Resources>
										</Button>

										<Button Grid.Column="1"
												Content="ROSTER"
												Click="Roster_Click"
												Tag="{Binding TeamID}"
												Background="#3A3A3A"
												Foreground="White"
												BorderThickness="0"
												FontWeight="SemiBold"
												FontSize="11"
												Cursor="Hand">
											<Button.Resources>
												<Style TargetType="Border">
													<Setter Property="CornerRadius" Value="0,0,8,0"/>
												</Style>
											</Button.Resources>
										</Button>
									</Grid>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>