<Page x:Class="Frontend.TeamsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Teams" Background="#0D0D0D">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Compact Header -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,16">
            <Grid>
                <StackPanel HorizontalAlignment="Left">
                    <Button Content="← BACK TO SEASONS" Click="Back_Click"
                            Style="{StaticResource GhostButton}"
                            FontSize="11" FontWeight="Bold"
                            HorizontalAlignment="Left" Margin="0,0,0,8"/>
                    <TextBlock x:Name="SeasonHeader" FontSize="22" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <Button x:Name="AddTeamButton" Content="+ ADD TEAM"
                        Click="AddTeam_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Visibility="Collapsed"
                        Background="#F05A28" Foreground="White" BorderThickness="0"
                        Padding="14,8" FontSize="11" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
            <Rectangle Height="1" Fill="#2E2E2E" Margin="0,12,0,0"/>
        </StackPanel>

        <!-- Left: Team Tiles -->
        <ScrollViewer Grid.Row="1" Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,16,0">
            <ItemsControl x:Name="TeamsList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Height="160"
                                CornerRadius="8" Background="#242424"
                                BorderBrush="#2E2E2E" BorderThickness="1"
                                Margin="0,0,12,12" ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="28"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Team identity — view mode -->
                                <Grid Grid.Row="0" Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="🛡️" FontSize="24"
                                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                        <TextBlock Text="{Binding TeamName}" FontSize="14"
                                                   FontWeight="Bold" Foreground="White"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   Margin="12,0,12,0"/>
                                    </StackPanel>
                                    <Button Content="⋮" Width="26" Height="26"
                                            Style="{StaticResource GhostButton}"
                                            FontSize="15"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,4,4,0" Tag="{Binding}"
                                            Click="TeamOptions_Click">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Edit" Click="EditTeam_Click"/>
                                                <MenuItem Header="Delete" Style="{StaticResource DeleteMenuItemStyle}" Click="DeleteTeam_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>

                                <!-- Row 0: Team name edit — edit mode -->
                                <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="14,8,14,8"
                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="🛡️" FontSize="24"
                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="TEAM NAME" Foreground="#999999"
                                               FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#1A1A1A" Foreground="White"
                                             BorderBrush="#F05A28" BorderThickness="1"
                                             Padding="8,5" FontSize="13" TextAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 1: W/L badges — hidden in edit mode -->
                                <StackPanel Grid.Row="1" Margin="0,2,0,5"
                                            Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center" Margin="0,0,0,3">
                                        <Border Background="#1A3A1A" CornerRadius="4"
                                                Padding="8,2" Margin="0,0,5,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Wins}" FontSize="13"
                                                           Foreground="#4CAF50" FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="W" FontSize="10" Foreground="#4CAF50"
                                                           Margin="2,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#3A1A1A" CornerRadius="4" Padding="8,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Losses}" FontSize="13"
                                                           Foreground="#FF4444" FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="L" FontSize="10" Foreground="#FF4444"
                                                           Margin="2,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding AverageScorePerGame, StringFormat='AVG {0} PTS'}"
                                               FontSize="10" Foreground="#999999"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 2: Action buttons — view mode -->
                                <Grid Grid.Row="2"
                                      Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="SCHEDULE"
                                            Click="TeamTile_Click" Tag="{Binding}"
                                            Background="#F05A28" Foreground="White"
                                            BorderThickness="0" FontWeight="SemiBold"
                                            FontSize="10" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,0,0,8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Grid.Column="1" Content="ROSTER"
                                            Click="Roster_Click" Tag="{Binding}"
                                            Background="#3A3A3A" Foreground="White"
                                            BorderThickness="0" FontWeight="SemiBold"
                                            FontSize="10" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,0,8,0"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>

                                <!-- Row 2: Save/Cancel — edit mode -->
                                <Grid Grid.Row="2"
                                      Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="✓  SAVE"
                                            Click="SaveTeam_Click" Tag="{Binding}"
                                            Background="#2E7D32" Foreground="White"
                                            BorderThickness="0" FontWeight="SemiBold"
                                            FontSize="10" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,0,0,8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Grid.Column="1" Content="✗  CANCEL"
                                            Click="CancelTeamEdit_Click" Tag="{Binding}"
                                            Background="#5A2A2A" Foreground="White"
                                            BorderThickness="0" FontWeight="SemiBold"
                                            FontSize="10" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,0,8,0"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Right: Stats Panels -->
        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Top">

            <!-- Standings -->
            <Border Background="#1A1A1A" BorderBrush="#2E2E2E"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="STANDINGS" FontSize="12" FontWeight="Bold"
                               Foreground="#F05A28" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TEAM" FontSize="10" Foreground="#555555" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="W" FontSize="10" Foreground="#555555" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="L" FontSize="10" Foreground="#555555" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="AVG" FontSize="10" Foreground="#555555" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#2E2E2E" Margin="0,0,0,8"/>

                    <ItemsControl x:Name="StandingsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TeamName}"
                                               FontSize="12" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Wins}"
                                               FontSize="12" Foreground="#4CAF50" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Losses}"
                                               FontSize="12" Foreground="#FF4444" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding AverageScorePerGame}"
                                               FontSize="12" Foreground="#999999" HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Most Active Players -->
            <Border Background="#1A1A1A" BorderBrush="#2E2E2E"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="MOST ACTIVE PLAYERS" FontSize="12" FontWeight="Bold"
                               Foreground="#F05A28" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PLAYER" FontSize="10" Foreground="#555555" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="GP" FontSize="10" Foreground="#555555" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="PTS" FontSize="10" Foreground="#555555" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="PPG" FontSize="10" Foreground="#555555" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#2E2E2E" Margin="0,0,0,8"/>

                    <ItemsControl x:Name="MostActivePlayersList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="{Binding SeasonRank}"
                                                   FontSize="10" Foreground="#F05A28"
                                                   FontWeight="Bold" Margin="0,0,5,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding PlayerName}"
                                                   FontSize="12" Foreground="White"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding GamesPlayed}"
                                               FontSize="12" Foreground="#999999" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TotalPoints}"
                                               FontSize="12" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding PointsPerGame}"
                                               FontSize="12" Foreground="#F05A28" HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Page>
