<Page x:Class="Frontend.TeamsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Teams" Background="#0D0D0D">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
            <Button Content="← BACK TO SEASONS" Click="Back_Click"
                    Style="{StaticResource GhostButton}"
                    FontSize="11" FontWeight="Bold"
                    HorizontalAlignment="Left" Margin="0,0,0,10"/>
            <Grid>
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="TEAMS" FontSize="30" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="SeasonHeader" FontSize="13" Foreground="#666666" Margin="0,2,0,0"/>
                </StackPanel>
                <Button x:Name="AddTeamButton"
                        Click="AddTeam_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Visibility="Collapsed"
                        Cursor="Hand" Foreground="White" FontSize="11" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#F05A28" CornerRadius="4" Padding="16,9">
                                <TextBlock Text="+ ADD TEAM" Foreground="White"
                                           FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#D94E22"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            <Rectangle Height="1" Fill="#2A2A2A" Margin="0,14,0,0"/>
        </StackPanel>

        <!-- Left: Team Tiles -->
        <ScrollViewer Grid.Row="1" Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,20,0">
            <ItemsControl x:Name="TeamsList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="230" Height="185"
                                CornerRadius="8" BorderThickness="1"
                                Margin="0,0,14,14" ClipToBounds="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1E1E1E"/>
                                    <Setter Property="BorderBrush" Value="#303030"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#242424"/>
                                            <Setter Property="BorderBrush" Value="#444444"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Team identity — view mode -->
                                <Grid Grid.Row="0" Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="🛡️" FontSize="26"
                                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding TeamName}" FontSize="15"
                                                   FontWeight="Bold" Foreground="White"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   Margin="14,0,14,0"/>
                                    </StackPanel>
                                    <Button Content="⋮" Width="26" Height="26"
                                            Style="{StaticResource GhostButton}"
                                            FontSize="15"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,6,6,0" Tag="{Binding}"
                                            Click="TeamOptions_Click">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Edit" Click="EditTeam_Click"/>
                                                <MenuItem Header="Delete" Style="{StaticResource DeleteMenuItemStyle}" Click="DeleteTeam_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>

                                <!-- Row 0: Team name edit — edit mode -->
                                <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="14,10,14,10"
                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="🛡️" FontSize="26"
                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="TEAM NAME" Foreground="#666666"
                                               FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#141414" Foreground="White"
                                             BorderBrush="#F05A28" BorderThickness="1"
                                             Padding="8,6" FontSize="13" TextAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 1: W/L badges — hidden in edit mode -->
                                <StackPanel Grid.Row="1" Margin="0,4,0,6"
                                            Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center" Margin="0,0,0,4">
                                        <Border Background="#162616" CornerRadius="4"
                                                Padding="10,3" Margin="0,0,6,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Wins}" FontSize="13"
                                                           Foreground="#4CAF50" FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text=" W" FontSize="10" Foreground="#4CAF50"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#261616" CornerRadius="4" Padding="10,3">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Losses}" FontSize="13"
                                                           Foreground="#FF4444" FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text=" L" FontSize="10" Foreground="#FF4444"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding AverageScorePerGame, StringFormat='AVG {0} PTS'}"
                                               FontSize="10" Foreground="#555555"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 2: Action buttons — view mode -->
                                <Grid Grid.Row="2"
                                      Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Click="TeamTile_Click" Tag="{Binding}" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="#F05A28" CornerRadius="0,0,0,8">
                                                    <TextBlock Text="SCHEDULE" Foreground="White"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#D94E22"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Column="1" Click="Roster_Click" Tag="{Binding}" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="#2A2A2A" CornerRadius="0,0,8,0">
                                                    <TextBlock Text="ROSTER" Foreground="White"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#363636"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- Row 2: Save/Cancel — edit mode -->
                                <Grid Grid.Row="2"
                                      Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Click="SaveTeam_Click" Tag="{Binding}" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="#2E7D32" CornerRadius="0,0,0,8">
                                                    <TextBlock Text="✓  SAVE" Foreground="White"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#256628"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Column="1" Click="CancelTeamEdit_Click" Tag="{Binding}" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="#5A2A2A" CornerRadius="0,0,8,0">
                                                    <TextBlock Text="✗  CANCEL" Foreground="White"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#6E3333"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Right: Stats Panels -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Standings -->
                <Border Background="#161616" BorderBrush="#2A2A2A"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="STANDINGS" FontSize="11" FontWeight="Bold"
                                   Foreground="#F05A28" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="42"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TEAM" FontSize="10" Foreground="#444444" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="W" FontSize="10" Foreground="#444444" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="L" FontSize="10" Foreground="#444444" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="AVG" FontSize="10" Foreground="#444444" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#222222" Margin="0,0,0,8"/>

                        <ItemsControl x:Name="StandingsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="42"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TeamName}"
                                                   FontSize="12" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Wins}"
                                                   FontSize="12" Foreground="#4CAF50" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Losses}"
                                                   FontSize="12" Foreground="#FF4444" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding AverageScorePerGame}"
                                                   FontSize="12" Foreground="#888888" HorizontalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Most Active Players -->
                <Border Background="#161616" BorderBrush="#2A2A2A"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="MOST ACTIVE PLAYERS" FontSize="11" FontWeight="Bold"
                                   Foreground="#F05A28" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="PLAYER" FontSize="10" Foreground="#444444" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="GP" FontSize="10" Foreground="#444444" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="PTS" FontSize="10" Foreground="#444444" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="PPG" FontSize="10" Foreground="#444444" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#222222" Margin="0,0,0,8"/>

                        <ItemsControl x:Name="MostActivePlayersList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="34"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding SeasonRank}"
                                                       FontSize="10" Foreground="#F05A28"
                                                       FontWeight="Bold" Margin="0,0,5,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding PlayerName}"
                                                       FontSize="12" Foreground="White"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding GamesPlayed}"
                                                   FontSize="12" Foreground="#888888" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TotalPoints}"
                                                   FontSize="12" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding PointsPerGame}"
                                                   FontSize="12" Foreground="#F05A28" HorizontalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
